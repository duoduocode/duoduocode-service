<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.duoduocode.service.tag.mapper.TagMapper">

    <resultMap id="BaseResultMap" type="com.duoduocode.service.tag.entity.Tag">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="color" property="color"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, name, color, is_deleted, created_at
    </sql>

    <!-- 插入标签 -->
    <insert id="insert" parameterType="com.duoduocode.service.tag.entity.Tag" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag (
            user_id, name, color, is_deleted, created_at
        ) VALUES (
            #{userId}, #{name}, #{color}, #{isDeleted}, #{createdAt}
        )
    </insert>

    <!-- 更新标签 -->
    <update id="updateById" parameterType="com.duoduocode.service.tag.entity.Tag">
        UPDATE tag
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="color != null">color = #{color},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询标签 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tag
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <!-- 根据用户ID查询标签列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tag
        WHERE user_id = #{userId} AND is_deleted = 0
        ORDER BY created_at DESC
    </select>

    <!-- 检查标签名称是否存在 -->
    <select id="countByUserIdAndName" resultType="int">
        SELECT COUNT(1)
        FROM tag
        WHERE user_id = #{userId} AND name = #{name} AND is_deleted = 0
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

    <!-- 软删除标签 -->
    <update id="softDeleteById">
        UPDATE tag
        SET is_deleted = 1
        WHERE id = #{id}
    </update>

</mapper>
