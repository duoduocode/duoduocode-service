<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.duoduocode.service.budget.mapper.SpecialBudgetMapper">

    <resultMap id="BaseResultMap" type="com.duoduocode.service.budget.entity.SpecialBudget">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="status" property="status"/>
        <result column="note" property="note"/>
        <result column="completed_at" property="completedAt"/>
        <result column="actual_amount" property="actualAmount"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, name, total_amount, start_date, end_date, status, note, completed_at, actual_amount, created_at
    </sql>

    <!-- 插入专项预算 -->
    <insert id="insert" parameterType="com.duoduocode.service.budget.entity.SpecialBudget" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO special_budget (
            user_id, name, total_amount, start_date, end_date, status, note, actual_amount, created_at
        ) VALUES (
            #{userId}, #{name}, #{totalAmount}, #{startDate}, #{endDate}, #{status}, #{note}, #{actualAmount}, #{createdAt}
        )
    </insert>

    <!-- 根据ID更新专项预算 -->
    <update id="updateById" parameterType="com.duoduocode.service.budget.entity.SpecialBudget">
        UPDATE special_budget
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="note != null">note = #{note},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID查询专项预算 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM special_budget
        WHERE id = #{id}
    </select>

    <!-- 根据用户ID查询专项预算列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM special_budget
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <!-- 根据用户ID查询进行中的专项预算列表 -->
    <select id="selectOngoingByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM special_budget
        WHERE user_id = #{userId} AND status = 'ongoing'
        ORDER BY created_at DESC
    </select>

    <!-- 根据ID更新状态为已完成 -->
    <update id="updateStatusToCompleted">
        UPDATE special_budget
        SET status = 'completed',
            actual_amount = #{actualAmount},
            completed_at = NOW()
        WHERE id = #{id}
    </update>

    <!-- 根据ID删除专项预算 -->
    <delete id="deleteById">
        DELETE FROM special_budget
        WHERE id = #{id}
    </delete>

</mapper>
